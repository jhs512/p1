{
  "compilerOptions": {
    "target": "ES2018",
    "module": "preserve",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "lib": ["es2021", "dom"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "moduleResolution": "bundler"
  },
  "exclude": ["remotion.config.ts"]
}
